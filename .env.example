# TMDB — optional, a built-in read access token is provided by default
# TMDB_API_TOKEN=your_own_tmdb_read_access_token
# Cookie security - set to 'true' in production behind reverse proxy

# App
PORT=3456
NODE_ENV=production
JWT_SECRET=change_me_to_a_random_secret
DATABASE_URL=file:../data/oscarr.db
FRONTEND_URL=http://localhost:5173
# COOKIE_SECURE=true
# Trust X-Forwarded-* headers. Leave true behind Docker / Traefik / nginx / Caddy. Set to false
# only when Oscarr is exposed directly (no reverse proxy), otherwise clients can spoof their IP.
# TRUST_PROXY=true
# Setup security — minimum 8 characters recommended
SETUP_SECRET=change_me_to_a_random_secret
INSTALL_FILE_PATH=./data/install.json
# BACKUP_MAX_SIZE_MB=500

# Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@oscarr.app
