generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  displayName           String?
  passwordHash          String?
  avatar                String?   // resolved/cached URL — derived from avatarSource + matching UserProvider.providerAvatar (or the dicebear data URI)
  avatarSource          String?   // null = legacy/auto, "none" = initials fallback, "dicebear" = generated, otherwise a linked provider id ("plex", "discord", ...)
  avatarConfig          String?   // JSON for the dicebear generator: { style, seed } — lets the editor restore the user's choice next time
  role                  String    @default("user") // "admin" | "user"
  disabled              Boolean   @default(false) // true = login blocked or friendly-gated depending on AppSettings.disabledLoginMode
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  providers             UserProvider[]
  requests              MediaRequest[]
  approvedRequests      MediaRequest[] @relation("ApprovedBy")
  supportTickets        SupportTicket[]
  ticketMessages        TicketMessage[]
  notifications         UserNotification[]
  blacklistedMedia      BlacklistedMedia[] @relation("BlacklistCreatedBy")
  pushSubscriptions     PushSubscription[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // "admin", "user", "moderator", etc.
  permissions String   @default("[]") // JSON array of permission strings
  isDefault   Boolean  @default(false) // Assigned to new users automatically
  isSystem    Boolean  @default(false) // Cannot be deleted (admin, user)
  position    Int      @default(0) // Display order (lower = higher priority, like Discord)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserProvider {
  id                Int       @id @default(autoincrement())
  userId            Int
  provider          String    // "plex" | "email" | "discord" | "jellyfin" | ...
  providerId        String?   // External ID from the provider (plexId, discordId, etc.)
  providerToken     String?   // OAuth token for API calls
  providerUsername  String?   // Username from the provider
  providerEmail     String?   // Email from the provider (may differ from user email)
  providerAvatar    String?   // Avatar URL fetched from this provider (used by avatar source picker)
  createdAt         DateTime  @default(now())

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
}

model AuthProviderSettings {
  id         Int      @id @default(autoincrement())
  provider   String   @unique  // "email" | "plex" | "jellyfin" | "emby" | "discord" | ...
  enabled    Boolean  @default(false)
  config     String   @default("{}")  // JSON blob — OAuth creds, redirect URIs, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Media {
  id                  Int       @id @default(autoincrement())
  tmdbId              Int
  tvdbId              Int?
  mediaType           String    // "movie" | "tv"
  title               String
  overview            String?
  posterPath          String?
  backdropPath        String?
  releaseDate         String?
  voteAverage         Float?
  genres              String?   // JSON string array
  keywordIds          String?   // JSON array of TMDB keyword IDs, e.g. "[210024,818]"
  contentRating       String?   // Content rating from TMDB (e.g. "TV-MA", "18", "R")
  status              String    @default("unknown") // "unknown" | "pending" | "processing" | "available" | "deleted"
  radarrId            Int?
  sonarrId            Int?
  qualityProfileId    Int?      // Quality profile ID from Radarr/Sonarr
  availableAt         DateTime? // Set when status transitions to "available"
  lastMissingSearchAt DateTime? // Last time a missing episode search was triggered
  lastEpisodeInfo     String?   // JSON: latest episode added (e.g. {"season":2,"episode":5,"title":"..."})
  audioLanguages      String?   // JSON array of normalized audio languages, cached when available
  subtitleLanguages   String?   // JSON array of normalized subtitle languages, cached when available
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  requests            MediaRequest[]
  seasons             Season[]

  @@unique([tmdbId, mediaType])
  @@index([tvdbId])
  @@index([status])
  @@index([availableAt])
  @@index([radarrId])
  @@index([sonarrId])
  @@index([contentRating])
  @@index([status, availableAt])
}

model Season {
  id            Int       @id @default(autoincrement())
  mediaId       Int
  seasonNumber  Int
  episodeCount  Int       @default(0)
  status        String    @default("unknown") // "unknown" | "pending" | "available"

  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, seasonNumber])
}

model MediaRequest {
  id            Int       @id @default(autoincrement())
  mediaId       Int
  userId        Int
  status        String    @default("pending") // "pending" | "approved" | "declined" | "processing" | "available" | "failed"
  mediaType     String    // "movie" | "tv"
  seasons       String?   // JSON array of season numbers for TV requests, null = all seasons
  rootFolder    String?   // Root folder path override
  qualityOptionId Int?    // Selected quality option
  approvedById  Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy    User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  qualityOption QualityOption? @relation(fields: [qualityOptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([mediaId])
  @@index([status])
}

model SupportTicket {
  id            Int       @id @default(autoincrement())
  userId        Int
  subject       String
  status        String    @default("open") // "open" | "closed"
  createdAt     DateTime  @default(now())
  closedAt      DateTime?

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      TicketMessage[]
}

model TicketMessage {
  id            Int       @id @default(autoincrement())
  ticketId      Int
  userId        Int
  content       String
  createdAt     DateTime  @default(now())

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSettings {
  id                    Int       @id @default(1)
  defaultQualityProfile Int?      // Quality profile ID from Radarr/Sonarr
  defaultMovieFolder    String?   // Default root folder for movies
  defaultTvFolder       String?   // Default root folder for TV series
  defaultAnimeFolder    String?   // Default root folder for anime
  plexMachineId         String?   // Plex server machine identifier for access verification
  lastRadarrSync        DateTime? // Last Radarr sync timestamp
  lastSonarrSync        DateTime? // Last Sonarr sync timestamp
  syncIntervalHours     Int       @default(6) // Auto-sync interval in hours
  notificationMatrix    String?
  incidentBanner        String?   // Global incident banner text (null = no banner)
  disabledLoginMode     String    @default("friendly") // "block" | "friendly" — how to reject login for User.disabled=true
  autoApproveRequests   Boolean   @default(false)
  requestsEnabled       Boolean   @default(true)
  supportEnabled        Boolean   @default(true)
  calendarEnabled       Boolean   @default(true)
  siteName              String    @default("Oscarr")
  registrationEnabled   Boolean   @default(true)
  nsfwBlurEnabled       Boolean   @default(true)
  missingSearchCooldownMin Int   @default(60) // Minutes before allowing another missing search
  instanceLanguages     String    @default("[\"en\"]") // JSON array of ISO 639-1 codes, e.g. ["fr","en"]
  siteUrl               String?   // Public URL of the instance (e.g. https://oscarr.example.com) for notification links
  apiKey                String?   // API key for external access (health check, integrations)
  homepageLayout        String?   // JSON array of HomepageSection configs
  adminDashboardLayout  String?   // JSON: { version, items[{ i, x, y, w, h }] } — null = use defaults
  verboseRequestLog     Boolean   @default(false) // When true, every HTTP request is persisted to AppLog (debug only)
  customLinks           String    @default("[]") // JSON array of { id, label, url, icon, order } — admin-defined external links rendered in the user account modal
  setupChecklistDismissed Boolean @default(false)
  updatedAt             DateTime  @updatedAt
}

model CronJob {
  id              Int       @id @default(autoincrement())
  key             String    @unique // "full_sync" | "request_sync"
  label           String    // Display name
  cronExpression  String    @default("0 */6 * * *")
  enabled         Boolean   @default(true)
  lastRunAt       DateTime?
  lastStatus      String?   // "success" | "error"
  lastDuration    Int?      // ms
  lastResult      String?   // JSON result summary
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Service {
  id            Int       @id @default(autoincrement())
  name          String    // Display name (e.g. "Radarr Principal", "Sonarr 4K")
  type          String    // "radarr" | "sonarr" | "qbittorrent" | etc.
  config        String    // JSON object with service-specific config
  isDefault     Boolean   @default(false)
  enabled       Boolean   @default(true)
  webhookId     Int?      // ID of the webhook registered in the service (null = webhooks disabled)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  qualityMappings QualityMapping[]
  folderRules     FolderRule[]
}

model FolderRule {
  id            Int       @id @default(autoincrement())
  name          String    // Display name (e.g. "Animes", "Documentaires Film")
  priority      Int       @default(0) // Lower = evaluated first
  mediaType     String    // "movie" | "tv"
  conditions    String    // JSON array: [{ field, operator, value }]
  folderPath    String    // Target root folder path
  seriesType    String?   // Sonarr series type override: "anime" | "standard" | "daily"
  serviceId     Int?      // Target service for this rule
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())

  service       Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model QualityOption {
  id            Int       @id @default(autoincrement())
  label         String    @unique // "SD", "HD", "4K", "4K HDR"
  position      Int       @default(0) // Display order
  allowedRoles  String?   // JSON array of role names, null = all roles
  approvalMode  String?   // null = inherit global, "auto" = force auto-approve, "manual" = force manual
  createdAt     DateTime  @default(now())

  mappings      QualityMapping[]
  requests      MediaRequest[]
}

model QualityMapping {
  id                  Int       @id @default(autoincrement())
  qualityOptionId     Int
  serviceId           Int
  qualityProfileId    Int       // Profile ID from Radarr/Sonarr API
  qualityProfileName  String    // Cached name for display
  createdAt           DateTime  @default(now())

  qualityOption       QualityOption @relation(fields: [qualityOptionId], references: [id], onDelete: Cascade)
  service             Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([qualityOptionId, serviceId, qualityProfileId])
}

model AppLog {
  id            Int       @id @default(autoincrement())
  level         String    // "info" | "warn" | "error"
  label         String    // Category (e.g. "Sync", "Request", "Auth")
  message       String
  createdAt     DateTime  @default(now())

  @@index([label])
  @@index([createdAt])
}

model NotificationProviderConfig {
  id         Int      @id @default(autoincrement())
  providerId String   @unique          // "discord", "telegram", "email", "plugin:slack", etc.
  enabled    Boolean  @default(false)
  settings   String   @default("{}")   // JSON blob: { "webhookUrl": "...", "botToken": "..." }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BlacklistedMedia {
  id            Int       @id @default(autoincrement())
  tmdbId        Int
  mediaType     String    // "movie" | "tv"
  title         String    // Display name for admin reference
  posterPath    String?   // TMDB poster path for display
  reason        String?   // Optional reason
  createdById   Int?
  createdAt     DateTime  @default(now())

  createdBy     User?     @relation("BlacklistCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([tmdbId, mediaType])
}

model TmdbCache {
  id            Int       @id @default(autoincrement())
  cacheKey      String    @unique
  data          String    // JSON stringified
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
}

model PluginState {
  id              Int       @id @default(autoincrement())
  pluginId        String    @unique
  enabled         Boolean   @default(true)
  settings        String    @default("{}") // JSON blob for plugin-specific settings
  onInstallRan    Boolean   @default(false)
  // Latest release version as observed by the update checker — null if the plugin
  // isn't in the registry or no check has run yet. Updated by GET /plugins/updates.
  latestVersion   String?
  lastUpdateCheck DateTime?
  // 'registry' | 'local'. Set at install: 'registry' when /install received a repository,
  // 'local' otherwise (URL install, manual drop-in, or any pre-existing PluginState row).
  installSource   String    @default("local")
  // GitHub repository ("<owner>/<repo>") for registry installs. Used by the update checker
  // and the future auto-update job to look up releases without re-deriving from the plugin id
  // (which can be the legacy short form for ids that predate the new format).
  repository      String?
  autoUpdateEnabled    Boolean   @default(false)
  lastUpdateAttemptAt  DateTime?
  // 'success' | 'failed' | 'rolled-back'
  lastUpdateStatus     String?
  lastUpdateError      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UserNotification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // "request_approved" | "request_declined" | "media_available" | "plugin:xxx"
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  String?  // JSON (mediaId, requestId, tmdbId, etc.)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model Keyword {
  id        Int      @id @default(autoincrement())
  tmdbId    Int      @unique
  name      String
  tag       String?  // "nsfw", "anime", or any custom tag
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patchnote {
  id      Int      @id @default(autoincrement())
  version String   @unique
  type    String   // "major" | "minor" | "patch"
  date    DateTime
  titleEn String
  titleFr String
  entries String   // JSON: [{ type: "feat"|"fix"|"perf", titleEn, titleFr, descEn?, descFr? }]
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PluginLog {
  id        Int      @id @default(autoincrement())
  pluginId  String
  level     String   // "info" | "warn" | "error" | "debug"
  message   String
  createdAt DateTime @default(now())

  @@index([pluginId, createdAt])
}
