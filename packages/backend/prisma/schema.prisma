generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  displayName           String?
  passwordHash          String?
  avatar                String?
  role                  String    @default("user") // "admin" | "user"
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  providers             UserProvider[]
  requests              MediaRequest[]
  approvedRequests      MediaRequest[] @relation("ApprovedBy")
  supportTickets        SupportTicket[]
  ticketMessages        TicketMessage[]
  notifications         UserNotification[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // "admin", "user", "moderator", etc.
  permissions String   @default("[]") // JSON array of permission strings
  isDefault   Boolean  @default(false) // Assigned to new users automatically
  isSystem    Boolean  @default(false) // Cannot be deleted (admin, user)
  position    Int      @default(0) // Display order (lower = higher priority, like Discord)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserProvider {
  id                Int       @id @default(autoincrement())
  userId            Int
  provider          String    // "plex" | "email" | "discord" | "jellyfin" | ...
  providerId        String?   // External ID from the provider (plexId, discordId, etc.)
  providerToken     String?   // OAuth token for API calls
  providerUsername  String?   // Username from the provider
  providerEmail     String?   // Email from the provider (may differ from user email)
  createdAt         DateTime  @default(now())

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
}

model Media {
  id                  Int       @id @default(autoincrement())
  tmdbId              Int
  tvdbId              Int?
  mediaType           String    // "movie" | "tv"
  title               String
  overview            String?
  posterPath          String?
  backdropPath        String?
  releaseDate         String?
  voteAverage         Float?
  genres              String?   // JSON string array
  status              String    @default("unknown") // "unknown" | "pending" | "processing" | "available" | "deleted"
  radarrId            Int?
  sonarrId            Int?
  qualityProfileId    Int?      // Quality profile ID from Radarr/Sonarr
  availableAt         DateTime? // Set when status transitions to "available"
  lastMissingSearchAt DateTime? // Last time a missing episode search was triggered
  lastEpisodeInfo     String?   // JSON: latest episode added (e.g. {"season":2,"episode":5,"title":"..."})
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  requests            MediaRequest[]
  seasons             Season[]

  @@unique([tmdbId, mediaType])
}

model Season {
  id            Int       @id @default(autoincrement())
  mediaId       Int
  seasonNumber  Int
  episodeCount  Int       @default(0)
  status        String    @default("unknown") // "unknown" | "pending" | "available"

  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, seasonNumber])
}

model MediaRequest {
  id            Int       @id @default(autoincrement())
  mediaId       Int
  userId        Int
  status        String    @default("pending") // "pending" | "approved" | "declined" | "processing" | "available" | "failed"
  mediaType     String    // "movie" | "tv"
  seasons       String?   // JSON array of season numbers for TV requests, null = all seasons
  rootFolder    String?   // Root folder path override
  qualityOptionId Int?    // Selected quality option
  approvedById  Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy    User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  qualityOption QualityOption? @relation(fields: [qualityOptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([mediaId])
}

model SupportTicket {
  id            Int       @id @default(autoincrement())
  userId        Int
  subject       String
  status        String    @default("open") // "open" | "closed"
  createdAt     DateTime  @default(now())
  closedAt      DateTime?

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      TicketMessage[]
}

model TicketMessage {
  id            Int       @id @default(autoincrement())
  ticketId      Int
  userId        Int
  content       String
  createdAt     DateTime  @default(now())

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSettings {
  id                    Int       @id @default(1)
  defaultQualityProfile Int?      // Quality profile ID from Radarr/Sonarr
  defaultMovieFolder    String?   // Default root folder for movies
  defaultTvFolder       String?   // Default root folder for TV series
  defaultAnimeFolder    String?   // Default root folder for anime
  plexMachineId         String?   // Plex server machine identifier for access verification
  lastRadarrSync        DateTime? // Last Radarr sync timestamp
  lastSonarrSync        DateTime? // Last Sonarr sync timestamp
  syncIntervalHours     Int       @default(6) // Auto-sync interval in hours
  discordWebhookUrl     String?   // Discord webhook URL for notifications
  telegramBotToken      String?
  telegramChatId        String?
  resendApiKey          String?
  resendFromEmail       String?
  resendToEmail         String?
  notificationMatrix    String?
  incidentBanner        String?   // Global incident banner text (null = no banner)
  autoApproveRequests   Boolean   @default(false)
  requestsEnabled       Boolean   @default(true)
  supportEnabled        Boolean   @default(true)
  calendarEnabled       Boolean   @default(true)
  siteName              String    @default("Oscarr")
  registrationEnabled   Boolean   @default(true)
  missingSearchCooldownMin Int   @default(60) // Minutes before allowing another missing search
  updatedAt             DateTime  @updatedAt
}

model CronJob {
  id              Int       @id @default(autoincrement())
  key             String    @unique // "full_sync" | "request_sync"
  label           String    // Display name
  cronExpression  String    @default("0 */6 * * *")
  enabled         Boolean   @default(true)
  lastRunAt       DateTime?
  lastStatus      String?   // "success" | "error"
  lastDuration    Int?      // ms
  lastResult      String?   // JSON result summary
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Service {
  id            Int       @id @default(autoincrement())
  name          String    // Display name (e.g. "Radarr Principal", "Sonarr 4K")
  type          String    // "radarr" | "sonarr" | "qbittorrent" | etc.
  config        String    // JSON object with service-specific config
  isDefault     Boolean   @default(false)
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  qualityMappings QualityMapping[]
  folderRules     FolderRule[]
}

model FolderRule {
  id            Int       @id @default(autoincrement())
  name          String    // Display name (e.g. "Animes", "Documentaires Film")
  priority      Int       @default(0) // Lower = evaluated first
  mediaType     String    // "movie" | "tv" | "all"
  conditions    String    // JSON array: [{ field, operator, value }]
  folderPath    String    // Target root folder path
  seriesType    String?   // Sonarr series type override: "anime" | "standard" | "daily"
  serviceId     Int?      // Target service for this rule
  createdAt     DateTime  @default(now())

  service       Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model QualityOption {
  id            Int       @id @default(autoincrement())
  label         String    @unique // "SD", "HD", "4K", "4K HDR"
  position      Int       @default(0) // Display order
  createdAt     DateTime  @default(now())

  mappings      QualityMapping[]
  requests      MediaRequest[]
}

model QualityMapping {
  id                  Int       @id @default(autoincrement())
  qualityOptionId     Int
  serviceId           Int
  qualityProfileId    Int       // Profile ID from Radarr/Sonarr API
  qualityProfileName  String    // Cached name for display
  createdAt           DateTime  @default(now())

  qualityOption       QualityOption @relation(fields: [qualityOptionId], references: [id], onDelete: Cascade)
  service             Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([qualityOptionId, serviceId, qualityProfileId])
}

model AppLog {
  id            Int       @id @default(autoincrement())
  level         String    // "info" | "warn" | "error"
  label         String    // Category (e.g. "Sync", "Request", "Auth")
  message       String
  createdAt     DateTime  @default(now())

  @@index([label])
  @@index([createdAt])
}

model TmdbCache {
  id            Int       @id @default(autoincrement())
  cacheKey      String    @unique
  data          String    // JSON stringified
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
}

model PluginState {
  id            Int       @id @default(autoincrement())
  pluginId      String    @unique
  enabled       Boolean   @default(true)
  settings      String    @default("{}") // JSON blob for plugin-specific settings
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model UserNotification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // "request_approved" | "request_declined" | "media_available" | "plugin:xxx"
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  String?  // JSON (mediaId, requestId, tmdbId, etc.)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}
